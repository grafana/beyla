# Minimal dev image for fast webhook iteration.
#
# This skips the full multi-stage build (eBPF compilation, Java agent) and
# just packages a pre-built binary. Use this when iterating on Go code in
# pkg/webhook/ — rebuild time drops from ~5 min to ~1 min.
#
# Usage:
#   make compile
#   docker build -t beyla:local -f pkg/webhook/docs/Dockerfile.dev .
FROM scratch
COPY bin/beyla /beyla
COPY --from=alpine:3.20 /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
ENTRYPOINT ["/beyla"]
